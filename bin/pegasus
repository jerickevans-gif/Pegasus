}

cmd_tutorial() {
  clear || true
  local STEPS=8
  local STEP=0

  pause() { printf "\n${BOLD}Press Enter to continue (or Ctrl-C to bail)...${RESET}"; read -r _ </dev/tty || true; }
  step() { STEP=$((STEP+1)); printf "\n${BOLD}━━━ Step %d/%d: %s ━━━${RESET}\n\n" "$STEP" "$STEPS" "$1"; }

  echo "${BOLD}Pegasus interactive tutorial${RESET}"
  echo "8 quick steps. ~10 minutes. Bail anytime with Ctrl-C."
  pause

  step "Make sure your install is healthy"
  cmd_check
  pause

  step "Pick where your work lives"
  echo "Pegasus puts every project under ~/Design-Projects/."
  echo "Right now you have:"
  ls "$PROJECTS_DIR" 2>/dev/null | head -10
  pause

  step "See your active skills (Claude Code + OpenCode read these)"
  echo "Top 5 of $(ls "$HOME/.claude/skills/" 2>/dev/null | wc -l | tr -d ' ') installed skills:"
  ls "$HOME/.claude/skills/" 2>/dev/null | head -5 | sed 's/^/  · /'
  echo "(Run 'pegasus skills' for the full list with descriptions)"
  pause

  step "Make a test project"
  echo "We'll scaffold a test portfolio (you can delete after):"
  echo "  ${BLUE}pegasus new portfolio tutorial-test${RESET}"
  printf "Run it now? [Y/n] "
  read -r ans </dev/tty || ans="y"
  if [[ "${ans:-y}" =~ ^[Yy]$ ]]; then cmd_new portfolio tutorial-test 2>&1 | tail -5; fi
  pause

  step "Open the visual dashboard"
  echo "  ${BLUE}pegasus dashboard${RESET}"
  echo "  Click any card → copies to clipboard. Paste into VS Code terminal."
  pause

  step "Try a workflow recipe"
  echo "  ${BLUE}pegasus run W4${RESET}   (Case Study Quick Drop, 30 min recipe)"
  echo "Walks you through chaining skills end-to-end."
  pause

  step "Set up your profile (optional but recommended)"
  echo "  ${BLUE}pegasus init${RESET}     (or edit in dashboard's Profile section)"
  echo "Skills like job-finder + interview-prep + content-writer use it."
  pause

  step "When you get stuck"
  echo "  ${BLUE}pegasus doctor${RESET}      diagnose what's installed"
  echo "  ${BLUE}pegasus heal${RESET}        self-repair missing assets"
  echo "  ${BLUE}pegasus bug${RESET}         file a bug report (gh issue with diagnostics pre-filled)"

  echo
  ok "${BOLD}Done.${RESET} Now build something."
}

cmd_check() {
  echo "${BOLD}Pegasus pre-flight check${RESET}"
  local OK=1

  # Network
  if curl -fsSL --max-time 5 https://github.com >/dev/null 2>&1; then ok "Internet reachable"
  else err "github.com unreachable"; OK=0; fi
  if curl -fsSL --max-time 5 https://api.anthropic.com >/dev/null 2>&1 || true; then ok "anthropic.com reachable"
  else warn "anthropic.com unreachable (Claude needs this)"; fi

  # Disk
  local AVAIL_GB=$(($(df -k "$HOME" | awk 'NR==2{print $4}') / 1024 / 1024))
  if [[ $AVAIL_GB -ge 2 ]]; then ok "Disk space: ${AVAIL_GB}GB free"
  else err "Only ${AVAIL_GB}GB free (need ~2GB for skills + templates + projects)"; OK=0; fi

  # Permissions
  if touch "$HOME/.pegasus-check-test" 2>/dev/null && rm "$HOME/.pegasus-check-test"; then ok "Write permission to \$HOME"
  else err "Can't write to \$HOME"; OK=0; fi

  # PATH
  case ":$PATH:" in
    *":$HOME/.local/bin:"*) ok "~/.local/bin on PATH" ;;
    *) warn "~/.local/bin NOT on PATH (pegasus helper may not be reachable)" ;;
  esac

  # Claude / OpenCode reachable
  have claude   && ok "Claude Code on PATH"   || warn "Claude Code missing"
  have opencode && ok "OpenCode on PATH"      || warn "OpenCode missing"
  have code     && ok "VS Code 'code' on PATH" || warn "VS Code 'code' missing — open VS Code → Cmd+Shift+P → 'Install code command in PATH'"

  echo
  if [[ $OK -eq 1 ]]; then
    ok "${BOLD}Ready to ship.${RESET}"
  else
    err "Some critical checks failed. Re-run install.sh after fixing."
    return 1
  fi
}

cmd_voice() {
  local action="${1:-install}"
  case "$action" in
    install)
      echo "${BOLD}Installing voice tools (Whisper STT + Kokoro TTS)${RESET}"
      if [[ "$(uname -s)" == "Darwin" ]]; then
        if have brew; then
          brew list whisper-cpp >/dev/null 2>&1 && ok "whisper-cpp already installed." \
            || (say "Installing whisper-cpp..."; brew install whisper-cpp 2>&1 | tail -3 && ok "whisper-cpp installed.")
        else
          warn "Homebrew not found. Install from https://brew.sh first."
        fi
      else
        warn "Linux: install whisper.cpp via your package manager or https://github.com/ggerganov/whisper.cpp"
      fi
      if have uv; then
        say "Installing kokoro-onnx (TTS) via uv..."
        uv tool install kokoro-onnx 2>&1 | tail -3 && ok "kokoro-onnx installed." || warn "kokoro-onnx install failed (optional)."
      else
        warn "uv not found — install with: curl -LsSf https://astral.sh/uv/install.sh | sh"
      fi
      echo
      ok "${BOLD}Voice tools installed.${RESET}"
      echo "Try:"
      echo "  ${BOLD}pegasus tutorial${RESET}              interactive 8-step guided walkthrough
  ${BOLD}pegasus heal${RESET} [--dry-run]    self-repair (re-fetch missing skills/templates/dashboard)
  ${BOLD}pegasus log${RESET}                   tail the install log
  ${BOLD}pegasus check${RESET}                 pre-flight diagnostic (network/disk/perms/PATH)
  ${BOLD}pegasus voice transcribe${RESET} <audio-file>     speech to text"
      echo "  ${BOLD}pegasus tutorial${RESET}              interactive 8-step guided walkthrough
  ${BOLD}pegasus heal${RESET} [--dry-run]    self-repair (re-fetch missing skills/templates/dashboard)
  ${BOLD}pegasus log${RESET}                   tail the install log
  ${BOLD}pegasus check${RESET}                 pre-flight diagnostic (network/disk/perms/PATH)
  ${BOLD}pegasus voice speak${RESET} \"Hello world\"           text to speech"
      echo "  In Claude/OpenCode: 'transcribe this voice memo + extract the design brief'"
      ;;
    transcribe)
      local f="${2:-}"
      if [[ -z "$f" || ! -f "$f" ]]; then err "Usage: pegasus voice transcribe <audio-file>"; exit 1; fi
      if ! have whisper-cli; then err "whisper-cpp not installed. Run: pegasus voice install"; exit 1; fi
      whisper-cli -f "$f" -m ~/.cache/whisper/ggml-base.en.bin 2>/dev/null || \
        (echo "Need to download model first..."; mkdir -p ~/.cache/whisper && curl -L -o ~/.cache/whisper/ggml-base.en.bin https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin && whisper-cli -f "$f" -m ~/.cache/whisper/ggml-base.en.bin)
      ;;
    speak)
      local text="${*:2}"
      if [[ -z "$text" ]]; then err "Usage: pegasus voice speak \"text to speak\""; exit 1; fi
      if [[ "$(uname -s)" == "Darwin" ]] && have say; then
        say "$text"  # macOS built-in 'say' command — instant, no install
      else
        warn "Voice TTS needs kokoro-onnx (run: pegasus voice install) or use macOS 'say'."
      fi
      ;;
    *) err "Usage: pegasus voice <install|transcribe|speak>" ;;
  esac
}

cmd_run() {
  local id="${1:-}"
  if [[ -z "$id" ]]; then
    echo "${BOLD}Usage:${RESET} pegasus run <W##>   (e.g. pegasus run W5)"
    echo "Available workflows:"
    echo "  W1  Figma → Live Portfolio          W6  Weekly Pipeline Triage"
    echo "  W2  Procreate Art → Showcase        W7  Interview Sprint (24h)"
    echo "  W3  Design System Spec → Components W8  Offer → Counter-Offer"
    echo "  W4  Case Study Quick Drop           W9  Portfolio → Job Application"
    echo "  W5  Job Posting → Sent App          W10 Case Study → Interview Stories"
    exit 1
  fi
  local wf="$PEGASUS_HOME/templates/auto-mode/workflows.md"
  if [[ ! -f "$wf" ]]; then
    err "workflows.md not found. Run: pegasus update"
    exit 1
  fi
  echo "${BOLD}Workflow $id${RESET}"
  # Extract steps for this workflow ID
  local steps
  steps=$(awk "/^### $id /,/^---/" "$wf" | head -50)
  echo "$steps"
  echo
  if ! have claude; then warn "Claude Code not installed — can only show steps."; return 0; fi
  echo "${BOLD}Want me to start Claude with step 1 already loaded?${RESET} [Y/n]"
  read -r ans </dev/tty || ans="y"
  if [[ "${ans:-y}" =~ ^[Yy]$ ]]; then
    # Extract the first numbered step's prompt
    local first_step
    first_step=$(echo "$steps" | awk '/^1\. "/{flag=1; sub(/^1\. "/, ""); print; flag=0}' | head -1 | sed 's/"$//')
    if [[ -n "$first_step" ]]; then
      echo "Launching Claude with: $first_step"
      claude "$first_step"
    else
      echo "Couldn't auto-extract step 1 — launching Claude. Paste the steps manually."
      claude
    fi
  fi
}

cmd_snapshot() {
  local out="$HOME/Desktop/pegasus-snapshot-$(date +%Y%m%d-%H%M%S).json"
  echo "${BOLD}Building Pegasus snapshot...${RESET}"
  cat > "$out" <<EOF
{
  "version": "$PEGASUS_VERSION",
  "snapshot_date": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "machine": "$(uname -srm)",
  "profile": $(cat "$PEGASUS_HOME/profile.json" 2>/dev/null || echo 'null'),
  "skills_installed": $(ls "$HOME/.claude/skills/" 2>/dev/null | jq -R -s 'split("\n") | map(select(length > 0))' 2>/dev/null || echo '[]'),
  "templates_installed": $(ls "$PEGASUS_HOME/templates/" 2>/dev/null | jq -R -s 'split("\n") | map(select(length > 0))' 2>/dev/null || echo '[]'),
  "projects": $(ls "$PROJECTS_DIR/" 2>/dev/null | jq -R -s 'split("\n") | map(select(length > 0))' 2>/dev/null || echo '[]'),
  "mcps_claude": $(claude mcp list 2>/dev/null | grep -E '^[a-z-]+:' | sed 's/:.*//' | jq -R -s 'split("\n") | map(select(length > 0))' 2>/dev/null || echo '[]')
}
EOF
  ok "Snapshot saved to $out"
  echo "Use it for backup, sharing your setup, or migrating to a new machine."
}

cmd_install_skill() {
  local what="${1:-}"
  if [[ -z "$what" ]]; then
    echo "${BOLD}Usage:${RESET} pegasus install <skill-name|github-url>"
    echo "Examples:"
    echo "  pegasus install ux-ui-audit                              # re-install a Pegasus skill"
    echo "  pegasus install https://github.com/SonwaneyY/Portfolio-Case-Study"
    exit 1
  fi
  if [[ "$what" =~ ^https?:// ]]; then
    local repo_name=$(basename "$what" .git)
    local dest="$HOME/.claude/skills/$repo_name"
    if [[ -d "$dest" ]]; then warn "$dest already exists."; exit 0; fi
    say "Cloning $what into ~/.claude/skills/..."
    git clone --depth 1 "$what" "$dest" || { err "Clone failed."; exit 1; }
    ok "Installed at $dest"
  else
    local src_url="$RAW/skills/$what/SKILL.md"
    local dest="$HOME/.claude/skills/$what"
    mkdir -p "$dest"
    curl -fsSL "$src_url" -o "$dest/SKILL.md" 2>/dev/null && ok "Installed skill: $what" || err "Couldn't fetch $what"
  fi
}

cmd_pulse() {
  echo "${BOLD}Pegasus Pulse${RESET} — your activity from the dashboard"
  echo
  echo "Note: stats live in the dashboard's localStorage. Run \`pegasus dashboard\` and"
  echo "scroll to the Pulse section to see counts, weekly activity, skills tried, day streak,"
  echo "and your recently-used items."
  echo
  echo "If you've never opened the dashboard, all counts will be zero."
  echo
  if have open || have xdg-open; then
    printf "%sOpen dashboard now? [Y/n] %s" "$BOLD" "$RESET"
    read -r yn </dev/tty || yn="y"
    [[ "${yn:-y}" =~ ^[Yy]$ ]] && cmd_dashboard
  fi
}

cmd_test() {
  echo "${BOLD}Pegasus end-to-end test${RESET}"
  local pass=0 fail=0
  test_check() {
    local name="$1"; local result="$2"
    if [[ "$result" == "ok" ]]; then ok "$name"; pass=$((pass+1))
    else err "$name"; fail=$((fail+1))
    fi
  }
  test_check "Helper on PATH"            "$(have pegasus && echo ok || echo no)"
  test_check "Templates folder"          "$([[ -d "$TEMPLATES_DIR" ]] && echo ok || echo no)"
  test_check "Design-Projects folder"    "$([[ -d "$PROJECTS_DIR" ]] && echo ok || echo no)"
  test_check "Cheatsheets installed"     "$([[ -f "$PROJECTS_DIR/COMMANDS.md" ]] && echo ok || echo no)"
  test_check "Dashboard at ~/.pegasus"   "$([[ -f "$PEGASUS_HOME/dashboard.html" ]] && echo ok || echo no)"
  test_check "Favicon at ~/.pegasus"     "$([[ -f "$PEGASUS_HOME/favicon.svg" ]] && echo ok || echo no)"
  test_check "Claude Code"               "$(have claude && echo ok || echo no)"
  test_check "OpenCode"                  "$(have opencode && echo ok || echo no)"
  test_check "VS Code (code)"            "$(have code && echo ok || echo no)"
  test_check "Surge (free deploy)"       "$(have surge && echo ok || echo no)"
  test_check "Git"                       "$(have git && echo ok || echo no)"
  test_check "Node"                      "$(have node && echo ok || echo no)"
  test_check "ImageMagick"               "$(have magick && echo ok || echo no)"
  test_check "potrace (vector tracing)"  "$(have potrace && echo ok || echo no)"
  test_check "svgo (SVG optimization)"   "$(have svgo && echo ok || echo no)"
  test_check "pegasus skills installed"  "$([[ -d "$HOME/.claude/skills/ux-ui-audit" ]] && echo ok || echo no)"
  echo
  echo "${BOLD}Results:${RESET} ${GREEN}$pass passing${RESET} · ${RED}$fail failing${RESET}"
  if [[ $fail -gt 0 ]]; then
    echo
    warn "Run 'pegasus update' or re-run install.sh to recover anything missing."
  fi
}

cmd_bug() {
  local DIAG=$(mktemp)
  {
    echo "## Pegasus diagnostics"
    echo ""
    echo "**Pegasus version:** $PEGASUS_VERSION"
    echo "**OS:** $(uname -srm)"
    echo "**Shell:** $SHELL"
    echo ""
    echo "### \`pegasus doctor\` output"
    echo '```'
    cmd_doctor 2>&1 || true
    echo '```'
    echo ""
    echo "### Versions"
    echo '```'
    have claude   && echo "claude:   $(claude --version 2>&1 | head -1)"
    have opencode && echo "opencode: $(opencode --version 2>&1 | head -1)"
    have node     && echo "node:     $(node --version)"
    have npm      && echo "npm:      $(npm --version)"
    have git      && echo "git:      $(git --version)"
    echo '```'
    echo ""
    echo "## Describe the issue"
    echo ""
    echo "<!-- What were you trying to do? What happened? What did you expect? -->"
  } > "$DIAG"
  ok "Diagnostics written to $DIAG"
  echo "Opening GitHub to create the issue with this content..."
  if have gh; then
    gh issue create --repo jerickevans-gif/Pegasus --title "[bug] " --body-file "$DIAG"
  else
    open_url "https://github.com/jerickevans-gif/Pegasus/issues/new"
    echo "Paste the contents of $DIAG into the issue body."
  fi
}

cmd_init() {
  clear || true
  cat <<EOF
${BOLD}Pegasus init${RESET} — guided setup, ~2 minutes.

We'll walk through:
  1. Your profile (name, role, links — used by job/interview/content skills)
  2. Which track you're focused on (UX Design / Job Search / both)
  3. Which design tools to enable bridges for (Figma, Webflow, etc.)
  4. Open the visual dashboard

Press Enter to start, Ctrl-C to bail.
EOF
  read -r _ </dev/tty || true

  # 1. Profile
  header "1 / 4  Your profile"
  local PROFILE_FILE="$PEGASUS_HOME/profile.json"
  mkdir -p "$PEGASUS_HOME"
  declare -A P
  P[name]=""; P[headline]=""; P[email]=""; P[location]=""; P[linkedin]=""; P[portfolio]=""; P[github]=""; P[resume]=""; P[skills]=""; P[bio]=""
  for k in name headline email location linkedin portfolio github resume skills bio; do
    local prompt
    case "$k" in
      name) prompt="Your full name" ;;
      headline) prompt="Headline / current role (e.g. 'Senior Product Designer')" ;;
      email) prompt="Email" ;;
      location) prompt="Location (e.g. 'Remote, US' or 'Brooklyn, NY')" ;;
      linkedin) prompt="LinkedIn URL (optional, Enter to skip)" ;;
      portfolio) prompt="Portfolio URL (optional)" ;;
      github) prompt="GitHub username (optional)" ;;
      resume) prompt="Path to resume (optional, e.g. ~/Design-Projects/resume/index.html)" ;;
      skills) prompt="Top skills, comma-separated (optional)" ;;
      bio) prompt="One-line bio (optional)" ;;
    esac
    printf "%s%s:%s " "$BOLD" "$prompt" "$RESET"
    read -r val </dev/tty || val=""
    P[$k]="$val"
  done
  # write JSON
  cat > "$PROFILE_FILE" <<JSON
{
  "name": "${P[name]}",
  "headline": "${P[headline]}",
  "email": "${P[email]}",
  "location": "${P[location]}",
  "linkedin": "${P[linkedin]}",
  "portfolio": "${P[portfolio]}",
  "github": "${P[github]}",
  "resume": "${P[resume]}",
  "skills": "${P[skills]}",
  "bio": "${P[bio]}"
}
JSON
  ok "Saved $PROFILE_FILE"

  # 2. Track
  header "2 / 4  Your focus this week"
  echo "  1) 🎨 UX Design — portfolio, case studies, mood boards"
  echo "  2) 💼 Job Search — resume tailoring, interview prep, job pulls"
  echo "  3) ⊕ Both"
  printf "%sPick 1, 2, or 3 (default 1): %s" "$BOLD" "$RESET"
  read -r tr </dev/tty || tr="1"
  case "${tr:-1}" in
    1) ok "Track set to UX Design (you can change in dashboard)" ;;
    2) ok "Track set to Job Search" ;;
    3) ok "Both tracks visible" ;;
  esac

  # 3. MCPs
  header "3 / 4  Design tool bridges"
  echo "Pegasus's defaults (UX Knowledge + Figma + Playwright + Context7) are auto-enabled."
  printf "%sAlso connect Webflow, Notion, GitHub, Linear, Stripe, Cloudflare? [y/N] %s" "$BOLD" "$RESET"
  read -r connect_more </dev/tty || connect_more="n"
  if [[ "$connect_more" =~ ^[Yy]$ ]]; then
    curl -fsSL "$RAW/connect.sh" | bash
  else
    echo "Skipped. Run later: pegasus signin  →  curl -fsSL $RAW/connect.sh | bash"
  fi

  # 4. Dashboard
  header "4 / 4  Your visual dashboard"
  ok "${BOLD}You're ready.${RESET}"
  echo
  echo "Try these next:"
  echo "  ${BOLD}pegasus dashboard${RESET}                   open the visual launcher"
  echo "  ${BOLD}pegasus new portfolio my-site${RESET}       scaffold your first project"
  echo "  ${BOLD}pegasus tour${RESET}                        5-min walkthrough"
  echo
  if have open || have xdg-open; then
    cmd_dashboard
  fi
}

cmd_profile() {
  local sub="${1:-show}"
  local PROFILE_FILE="$PEGASUS_HOME/profile.json"
  case "$sub" in
    show)
      if [[ -f "$PROFILE_FILE" ]]; then
        say "Profile at $PROFILE_FILE:"
        cat "$PROFILE_FILE"
      else
        warn "No profile yet. Open the dashboard (pegasus dashboard) → Your profile section,"
        warn "fill it in, click 'Download profile.json', then run:"
        echo "  pegasus profile import ~/Downloads/profile.json"
      fi
      ;;
    import)
      local src="${2:-}"
      if [[ -z "$src" || ! -f "$src" ]]; then err "Usage: pegasus profile import <path-to-profile.json>"; exit 1; fi
      mkdir -p "$PEGASUS_HOME"
      cp "$src" "$PROFILE_FILE" && ok "Imported to $PROFILE_FILE"
      echo "Skills will now reference this for personalized output."
      ;;
    edit)
      cmd_dashboard
      echo "Edit the 'Your profile' section in the dashboard, then click Download → re-import."
      ;;
    path)
      echo "$PROFILE_FILE"
      ;;
    *)
      echo "Usage: pegasus profile <show|edit|import <file>|path>"
      ;;
  esac
}

cmd_link() {
  local proj="${1:-}"
  if [[ -z "$proj" ]]; then warn "Usage: pegasus link <project-name>"; exit 1; fi
  local src="$PROJECTS_DIR/$proj"
  if [[ ! -d "$src" ]]; then err "$src doesn't exist."; exit 1; fi
  mkdir -p "$HOME/Sites"
  ln -sf "$src" "$HOME/Sites/$proj"
  ok "Symlinked $src → ~/Sites/$proj"
  echo "If you have macOS personal web sharing on, this is now at http://localhost/~$USER/$proj/"
  echo "Or run: cd ~/Sites/$proj && npx serve ."
}

