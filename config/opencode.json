{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "ux-knowledge": {
      "type": "local",
      "command": ["npx", "@elsahafy/ux-mcp-server"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/sse",
      "enabled": true
    }
  }
}
